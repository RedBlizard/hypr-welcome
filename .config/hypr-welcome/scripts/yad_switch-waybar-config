#!/bin/bash

WAYBAR_FLAG="$HOME/.config/waybar/scripts/waybar_flag"
logo_path="$HOME/.config/hypr-welcome/imgs/hypr-welcome.png"

WAYBAR_CONFIGS=("Desktop" "Laptop" "Minimal")

# If already configured, skip (optional safety)
if [ -e "$WAYBAR_FLAG" ]; then
    echo "Waybar already configured. Skipping."
    exit 0
fi

selected_config=$(printf "%s\n" "${WAYBAR_CONFIGS[@]}" | yad \
    --list \
    --column="Configuration" \
    --no-headers \
    --title="Pick your waybar" \
    --image="$logo_path" \
    --button=" Close")

if [ -z "$selected_config" ]; then
    echo "No selection made."
    exit 0
fi

# ----------------------------
# CONFIG PATHS
# ----------------------------
DESKTOP_CONFIG_PATH="$HOME/.config/waybar/conf/w1-config-desktop.jsonc"
LAPTOP_CONFIG_PATH="$HOME/.config/waybar/conf/w2-config-laptop.jsonc"
MINIMAL_CONFIG_PATH="$HOME/.config/waybar/conf/w3-config-desktop.jsonc"

DESKTOP_STYLE_PATH="$HOME/.config/waybar/style/w1-style.css"
LAPTOP_STYLE_PATH="$HOME/.config/waybar/style/w2-style.css"
MINIMAL_STYLE_PATH="$HOME/.config/waybar/style/w3-style.css"

# ----------------------------
# APPLY CONFIG
# ----------------------------
case "$selected_config" in
    "Desktop")
        ln -sf "$DESKTOP_CONFIG_PATH" "$HOME/.config/waybar/config.jsonc"
        ln -sf "$DESKTOP_STYLE_PATH" "$HOME/.config/waybar/style.css"
        ;;
    "Laptop")
        ln -sf "$LAPTOP_CONFIG_PATH" "$HOME/.config/waybar/config.jsonc"
        ln -sf "$LAPTOP_STYLE_PATH" "$HOME/.config/waybar/style.css"
        ;;
    "Minimal")
        ln -sf "$MINIMAL_CONFIG_PATH" "$HOME/.config/waybar/config.jsonc"
        ln -sf "$MINIMAL_STYLE_PATH" "$HOME/.config/waybar/style.css"
        ;;
    *)
        echo "Invalid selection"
        exit 1
        ;;
esac

# ----------------------------
# WALLPAPER (UNCHANGED LOGIC, FIXED SAFETY)
# ----------------------------
DIR="$HOME/Pictures/wallpapers-redblizard/"
PICS=("$DIR"/*)

RANDOMPICS=$(basename "${PICS[$RANDOM % ${#PICS[@]}]}")

pkill swaybg 2>/dev/null

pgrep -x swww-daemon >/dev/null || (swww-daemon & disown)

swww img "${DIR}/${RANDOMPICS}" --transition-step 20 --transition-fps=20

cp "${DIR}/${RANDOMPICS}" "$HOME/.cache/awww/current_wallpaper.png"

# ----------------------------
# RESTART WAYBAR
# ----------------------------
killall -q waybar
while pgrep -x waybar >/dev/null; do sleep 0.2; done
waybar &

# ----------------------------
# SET FLAG (IMPORTANT PART)
# ----------------------------
mkdir -p "$(dirname "$WAYBAR_FLAG")"
touch "$WAYBAR_FLAG"

echo "Waybar configured and flag set."
