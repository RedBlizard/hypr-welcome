#!/bin/bash

# Define paths and scripts (adjust paths as per your setup)
logo_path="$HOME/.config/hypr-welcome/imgs/hypr-welcome.png"
hypr_information_script="$HOME/.config/hypr-welcome/scripts/yad_settings"
hypr_keyhint_script="$HOME/.config/hypr-welcome/scripts/hypr-keyhint.sh"
hypr_awww_script="$HOME/.config/hypr-welcome/scripts/yad_awww"
wallpaper_selector_script="$HOME/.config/hypr-welcome/scripts/wofi_wallpaper_selector.sh -s"
keyring_repair_script="$HOME/.config/hypr-welcome/scripts/keyring_repair.sh"
refresh_yay_script="$HOME/.config/hypr-welcome/scripts/refresh-yay.sh"
pgp_key_repair_script="$HOME/.config/hypr-welcome/scripts/pgp_key_repair.sh"
system_update_script="$HOME/.config/hypr-welcome/scripts/system-update.sh"
update_mirrors_script="$HOME/.config/hypr-welcome/scripts/reflector_simple.sh"
eos_rankmirrors_script="$HOME/.config/hypr-welcome/scripts/eos-rankmirrors.sh"
eos_log_tool_script="$HOME/.config/hypr-welcome/scripts/eos-log-tool.sh"
cleanup_script="$HOME/.config/hypr-welcome/scripts/cleanup.sh"
kitty_script="$HOME/.config/hypr-welcome/scripts/yad_update_dots.sh"
waybar_script="$HOME/.config/hypr-welcome/scripts/yad_switch-waybar-config"
kill_script="$HOME/.config/hypr-welcome/scripts/kill-hypr-welcome"
hypr_blizz_update_script="$HOME/.config/hypr-welcome/scripts/hypr_blizz_update.sh"
hypr_welcome_update_script="$HOME/.config/hypr-welcome/scripts/hypr_welcome_update.sh"
hypr_waybar_update_script="$HOME/.config/hypr-welcome/scripts/hypr_waybar_update.sh"
hypr_blizz_repo="$HOME/hyprland-dots/Hyprland-blizz"
hypr_welcome_repo="$HOME/hyprland-dots/hypr-welcome"
hypr_waybar_repo="$HOME/hyprland-dots/hypr-waybar"

# Function to check network connectivity
check_network() {
    wget -q --spider http://google.com
    if [ $? -eq 0 ]; then
        return 0
    else
        echo "Network connection required. Please check your internet connection." >&2
        return 1
    fi
}

# Now returns the NUMBER of commits via echo
check_updates() {
    local repo_dir="$1"
    
    if [ ! -d "$repo_dir/.git" ]; then
        echo 0
        return 1
    fi
    
    (
        cd "$repo_dir" || { echo 0; exit 1; }
        
        if ! timeout 3 git fetch origin main --quiet 2>/dev/null; then
            echo 0
            exit 1
        fi
        
        git rev-list --count HEAD..origin/main 2>/dev/null || echo 0
    )
}

# Capture the number of commits PER repo
commits_welcome=$(check_updates "$hypr_welcome_repo")
commits_waybar=$(check_updates "$hypr_waybar_repo")
commits_blizz=$(check_updates "$hypr_blizz_repo")

# Booleans still work as before
update_hypr_welcome=false
update_hypr_waybar=false
update_hypr_blizz=false

[ "${commits_welcome:-0}" -gt 0 ] && update_hypr_welcome=true
[ "${commits_waybar:-0}"  -gt 0 ] && update_hypr_waybar=true
[ "${commits_blizz:-0}"   -gt 0 ] && update_hypr_blizz=true

# update_count is now the sum of ALL commits across all repos
update_count=$(( ${commits_welcome:-0} + ${commits_waybar:-0} + ${commits_blizz:-0} ))

# Go straight into the if block - no reset needed
if [ "$update_count" -gt 0 ]; then
    update_status="<span foreground='#FF7F7F'>  Hyprland updates: $update_count found</span>"
    
    if [ "$update_count" -gt 1 ]; then
        update_script="$kitty_script"
    elif $update_hypr_blizz; then
        update_script="$hypr_blizz_update_script"
    elif $update_hypr_welcome; then
        update_script="$hypr_welcome_update_script"
    elif $update_hypr_waybar; then
        update_script="$hypr_waybar_update_script"
    fi
else
    update_status="  Hyprland is up-to-date"
    update_script="$HOME/.config/hypr-welcome/scripts/no_updates.sh"
fi

# Debug output
echo "Update Status: $update_status"
echo "Update count:  $update_count"
echo "Update Script: $update_script"


