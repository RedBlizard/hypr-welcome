        --geometry=900x410+800+200 \
        --tabs-position=top \
        --no-buttons \
        --no-buttons \
        --tab="General info" \
            --form \
            --columns=3 \
            --field="<b><span font_desc='CustomFont 10'></span>   General info</b>:FBTN" "bash -c 'yad --notebook --tab=\"General info\" --form \
