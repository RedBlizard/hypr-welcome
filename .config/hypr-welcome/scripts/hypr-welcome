                --field=\"󱍸   Update Mirrors:FBTN\" \"bash $update_mirrors_script\" \
                --field=\"󱍸   Rank Mirrors:FBTN\" \"bash $eos_rankmirrors_script\" \
                --field=\"   System Logs:FBTN\" \"bash $eos_log_tool_script\" \
                --field=\"<span foreground='white'> </span>                                        :LBL\" \"\" \
                --field=\"<span foreground='white'> </span>                                        :LBL\" \"\" \
